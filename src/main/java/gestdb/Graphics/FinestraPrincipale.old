    public void InizializzaParteRemota(){
        jLabel11.setText("Gestione Comunicazione Database Remoto");
        jLabel18.setText("Gestione Database Remoto");
        jButton6.setText("Connessione");
        jButton6.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
            new ConnessioneDB().setVisible(true);
          }
        });
        jButton7.setText("Disconnessione");
        jButton7.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
            DisconnessioneDB.Disconnessione();
          }
        });
        jLabel13.setText("Comandi Database Remoto");
        jButton8.setText("Mostra Tabella");
        jButton8.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
              AvviaMostraTabella();
          }
        });

        jButton9.setText("Comandi DDL");
        jButton9.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
            AvviaFormQuery();
          }
        });
        jButton11.setText("Comandi DQL");
        jButton11.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
            AvviaFormQuery();
          }
        });
        jButton12.setText("Comandi DCL");
        jButton12.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
             AvviaFormQuery();
          }
        });
        jButton20.setText("Comandi DML");
        jButton20.addActionListener(new ActionListener(){
          @Override
          public void actionPerformed(ActionEvent e) {
            AvviaFormQuery();
          }
        });
    }
    
